{
  "db_name": "PostgreSQL",
  "query": "\n        SELECT\n            gr.snapshot_id,\n            gr.game_id,\n            gr.user_id,\n            gr.place,\n            g.closed_at\n        FROM game_results gr\n        JOIN games g ON g.id = gr.game_id\n        WHERE g.group_id = $1\n          AND g.closed_at IS NOT NULL\n        ORDER BY g.closed_at ASC, gr.snapshot_id ASC, gr.user_id ASC\n        ",
