  "query": "SELECT s.id, s.user_id, u.username, s.round, s.value, s.recorded_at\n                   FROM scores s\n                   JOIN users u ON u.id = s.user_id\n                   WHERE s.game_id = $1\n                   ORDER BY s.round ASC, u.username ASC",
